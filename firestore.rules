rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Analyses are publicly readable (or at least by signed-in users) but only system/admin should write them optimally.
    // For this app, we'll allow users to trigger creation via backend, but let's allow read for signed in users.
    match /analyses/{analysisId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // In a real production app, this might be restricted to an admin or a specific service account.
    }

    match /users/{userId}/savedProblems/{problemId} {
      allow read, write: if isOwner(userId);
    }
  }
}
